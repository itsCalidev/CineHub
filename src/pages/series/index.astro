---
// src/pages/series/index.astro

import Layout     from "../../layouts/Layout.astro";
import Header     from "../../components/Header.astro";
import Footer     from "../../components/Footer.astro";
import SeriesCard from "../../components/SeriesCard.astro";

import rawSeries from "../../data/series/series.json";

interface Plataforma {
  nombre: string;
  url:    string;
}

interface Serie {
  id:           number;
  title:        string;
  description:  string;
  image:        string;
  trailer:      string;
  categoria:    "reciente" | "clasico" | "proximo";
  plataformas:  Plataforma[];
  anio?:        number;
  creador?:     string;
  temporadas?:  number;
  episodios?:   number | null;
  calificacion?: number | null;
  genero?:      string[];
}

const series = rawSeries as Serie[];

const recientes = series.filter((s) => s.categoria === "reciente");
const clasicas  = series.filter((s) => s.categoria === "clasico");
const proximas  = series.filter((s) => s.categoria === "proximo");

const total = series.length;

const secciones = [
  {
    id:       "lo-mas-reciente",
    heading:  "heading-recientes",
    etiqueta: "Temporadas 2024-25",
    titulo:   ["Lo más", "Reciente"],
    acento:   "blue"  as const,
    icon:     "fa-solid fa-bolt",
    items:    recientes,
    href:     "/series?cat=reciente",
    bgClass:  "bg-[#0a0f1a]",
    wrapperClass: "",
  },
  {
    id:       "clasicos",
    heading:  "heading-clasicos",
    etiqueta: "Televisión Atemporal",
    titulo:   ["Clásicos", "Imprescindibles"],
    acento:   "amber" as const,
    icon:     "fa-solid fa-film",
    items:    clasicas,
    href:     "/series?cat=clasico",
    bgClass:  "bg-[#060b14]",
    wrapperClass: "clasico-card",
  },
  {
    id:       "proximamente",
    heading:  "heading-proximas",
    etiqueta: "Muy Pronto",
    titulo:   ["Próxi", "mamente"],
    acento:   "cyan"  as const,
    icon:     "fa-solid fa-calendar-days",
    items:    proximas,
    href:     "/series?cat=proximo",
    bgClass:  "bg-[#0a0f1a]",
    wrapperClass: "proximo-card",
  },
] as const;

const acentoStyles = {
  blue: {
    badge:      "bg-blue-600/20 border border-blue-500/30",
    icon:       "bg-blue-600/20 border border-blue-500/30 text-blue-400",
    etiqueta:   "text-blue-400",
    titular:    "text-blue-400",
    separador:  "from-blue-600/50",
    separadorIcon: "text-blue-500/50",
    navBtn:     "group-hover:bg-blue-600 group-hover:text-white group-hover:border-blue-600",
    verTodo:    "hover:text-blue-400",
    count:      "bg-blue-400",
  },
  amber: {
    badge:      "bg-amber-600/20 border border-amber-500/30",
    icon:       "bg-amber-600/20 border border-amber-500/30 text-amber-400",
    etiqueta:   "text-amber-400",
    titular:    "text-amber-400",
    separador:  "from-amber-600/40",
    separadorIcon: "text-amber-500/40",
    navBtn:     "group-hover:bg-amber-600 group-hover:text-white group-hover:border-amber-600",
    verTodo:    "hover:text-amber-400",
    count:      "bg-amber-400",
  },
  cyan: {
    badge:      "bg-cyan-600/20 border border-cyan-500/30",
    icon:       "bg-cyan-600/20 border border-cyan-500/30 text-cyan-400",
    etiqueta:   "text-cyan-400",
    titular:    "text-cyan-400",
    separador:  "from-cyan-600/40",
    separadorIcon: "text-cyan-500/40",
    navBtn:     "group-hover:bg-cyan-600 group-hover:text-white group-hover:border-cyan-600",
    verTodo:    "hover:text-cyan-400",
    count:      "bg-cyan-400",
  },
};
---

<Layout
  title="Series"
  description={`Explora nuestra selección de ${total} series: nuevas temporadas, clásicos esenciales y próximos estrenos. Cine-Hub.`}
>
  <Header />

  <main class="pt-[68px]">

    <section
      class="relative w-full h-[55vh] min-h-[380px] flex items-center justify-center overflow-hidden"
      aria-label="Cabecera de la sección Series"
    >

      <img
        src="/assets/fondo_series.webP"
        alt="Escena de televisión de calidad cinematográfica"
        class="absolute inset-0 w-full h-full object-cover object-center scale-105"
        loading="eager"
        onerror="this.src='https://images.unsplash.com/photo-1522869635100-9f4c5e86aa37?w=1600&q=80'; this.onerror=null;"
      />

      <div class="absolute inset-0 bg-[#0a0f1a]/78" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#0a0f1a]/50 via-transparent to-[#0a0f1a]" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0a0f1a]/60 via-transparent to-transparent" />

      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        {Array.from({ length: 18 }, (_, i) => (
          <span
            class="absolute rounded-full bg-blue-400/30 animate-pulse-slow"
            style={`
              width:  ${1 + (i % 2)}px;
              height: ${1 + (i % 2)}px;
              top:    ${8 + (i * 51) % 82}%;
              left:   ${4 + (i * 41) % 92}%;
              animation-delay:    ${(i * 0.25) % 3}s;
              animation-duration: ${2 + (i % 3)}s;
            `}
          />
        ))}
      </div>

      <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
        <nav aria-label="Breadcrumb" class="flex items-center justify-center gap-2 text-xs text-slate-500 mb-4">
          <a href="/" class="hover:text-blue-400 transition-colors">Inicio</a>
          <i class="fa-solid fa-chevron-right text-[8px]" />
          <span class="text-blue-400">Series</span>
        </nav>

        <div class="flex items-center justify-center gap-3 mb-4">
          <span class="w-8 h-[2px] bg-blue-500 rounded" />
          <span class="text-blue-400 font-['Barlow_Condensed'] uppercase tracking-[0.25em] text-xs font-semibold">
            Televisión de Calidad
          </span>
          <span class="w-8 h-[2px] bg-blue-500 rounded" />
        </div>

        <h1 class="font-['Bebas_Neue'] text-6xl sm:text-7xl lg:text-8xl text-white tracking-wide leading-none mb-4">
          Se<span class="text-blue-400">ries</span>
        </h1>

        <p class="text-slate-300 text-base sm:text-lg max-w-lg mx-auto mb-7">
          Desde las mejores temporadas del año hasta los clásicos que cambiaron la televisión.
          <span class="text-blue-400 font-semibold">{total} series</span> curadas para ti.
        </p>

        <div class="flex items-center justify-center gap-10">
          {[
            { valor: recientes.length, label: "Recientes",    dot: "bg-blue-400"  },
            { valor: clasicas.length,  label: "Clásicos",     dot: "bg-amber-400" },
            { valor: proximas.length,  label: "Próximamente", dot: "bg-cyan-400"  },
          ].map(({ valor, label, dot }) => (
            <div class="text-center flex flex-col items-center gap-1">
              <div class={`w-1.5 h-1.5 rounded-full ${dot} mb-0.5`} />
              <p class="font-['Bebas_Neue'] text-3xl text-white leading-none">{valor}</p>
              <p class="text-slate-500 text-[10px] uppercase tracking-widest">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sticky top-[68px] z-40 bg-[#0a0f1a]/90 backdrop-blur-xl border-b border-slate-800/60 shadow-lg shadow-black/30">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 py-4">

          <p class="text-slate-400 text-sm hidden md:block">
            <span class="text-white font-medium">{total} series</span> en tres categorías
          </p>

          <nav aria-label="Navegación por secciones de series" class="flex items-center gap-2 flex-wrap justify-center">
            {secciones.map(({ id, icon, titulo, acento, items }) => {
              const estilos = acentoStyles[acento];
              return (
                <a
                  href={`#${id}`}
                  class={`
                    group inline-flex items-center gap-2 px-4 py-2 rounded-lg
                    border border-slate-700/60
                    text-slate-300 text-sm font-medium
                    transition-all duration-200
                    ${estilos.navBtn}
                  `}
                >
                  <i class={`${icon} text-xs opacity-70 group-hover:opacity-100`} />
                  {titulo.join(" ")}
                  <span class="px-1.5 py-0.5 rounded bg-slate-800 group-hover:bg-white/20 text-slate-400 group-hover:text-current text-[10px] font-bold transition-colors">
                    {items.length}
                  </span>
                </a>
              );
            })}
          </nav>

          <div class="hidden lg:flex items-center gap-2 px-3 py-2 rounded-lg bg-slate-800/60 border border-slate-700/40 text-slate-500 text-sm">
            <i class="fa-solid fa-magnifying-glass text-xs" />
            <span>Buscar serie…</span>
          </div>
        </div>
      </div>
    </section>

    {secciones.map(({ id, heading, etiqueta, titulo, acento, icon, items, href, bgClass, wrapperClass }, secIdx) => {
      const estilos  = acentoStyles[acento];
      const esFinal  = secIdx === secciones.length - 1;
      const esProximo = id === "proximamente";

      return (
        <>
          <section
            id={id}
            class={`py-20 ${bgClass} scroll-mt-32`}
            aria-labelledby={heading}
          >
            <div class="max-w-7xl mx-auto px-6 lg:px-12">

              <header class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-10 animate-on-scroll">
                <div>
                  <div class="flex items-center gap-3 mb-2">
                    <div class={`w-9 h-9 rounded-lg flex items-center justify-center ${estilos.icon}`}>
                      <i class={`${icon} text-sm`} />
                    </div>
                    <span class={`font-['Barlow_Condensed'] uppercase tracking-[0.2em] text-xs font-semibold ${estilos.etiqueta}`}>
                      {etiqueta}
                    </span>
                  </div>
                  <h2
                    id={heading}
                    class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide"
                  >
                    {titulo[0]}&nbsp;<span class={estilos.titular}>{titulo[1]}</span>
                  </h2>
                </div>
                <a
                  href={href}
                  class={`inline-flex items-center gap-2 text-sm text-slate-400 transition-colors group shrink-0 ${estilos.verTodo}`}
                >
                  Ver todo
                  <i class="fa-solid fa-arrow-right transition-transform group-hover:translate-x-1" />
                </a>
              </header>

              <div class="flex items-center gap-4 mb-10">
                <div class={`h-[1px] flex-1 bg-gradient-to-r ${estilos.separador} to-transparent`} />
                <i class={`fa-solid fa-star text-xs ${estilos.separadorIcon}`} />
                <div class="h-[1px] w-16 bg-slate-800" />
              </div>

              {esProximo && (
                <div class="mb-6 flex items-center gap-3 p-4 rounded-xl bg-cyan-950/30 border border-cyan-800/30 animate-on-scroll">
                  <i class="fa-solid fa-circle-info text-cyan-400 text-sm shrink-0" />
                  <p class="text-slate-400 text-sm">
                    Fechas y detalles sujetos a cambios. Sin plataforma confirmada aún.
                    <a href="/noticias" class="text-cyan-400 hover:underline ml-1">Ver noticias →</a>
                  </p>
                </div>
              )}

              {items.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                  {items.map((serie, i) => (
                    <div
                      class={`animate-on-scroll ${wrapperClass}`}
                      style={`animation-delay: ${i * 0.12}s`}
                    >
                      <SeriesCard
                        title={serie.title}
                        description={serie.description}
                        image={serie.image}
                        trailer={serie.trailer}
                        plataformas={serie.plataformas ?? []}
                        anio={serie.anio}
                        creador={serie.creador}
                        temporadas={serie.temporadas}
                        episodios={serie.episodios ?? undefined}
                        calificacion={serie.calificacion ?? undefined}
                        genero={serie.genero}
                        showCategoria={esProximo}
                        categoria={serie.categoria}
                      />
                    </div>
                  ))}
                </div>
              ) : (
                <div class="flex flex-col items-center justify-center py-16 text-center gap-3">
                  <i class="fa-solid fa-tv text-slate-700 text-4xl" />
                  <p class="text-slate-500">No hay series en esta categoría por el momento.</p>
                </div>
              )}
            </div>
          </section>

          {!esFinal && (
            <div class="h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent mx-12" aria-hidden="true" />
          )}
        </>
      );
    })}

    <section class="py-16 bg-[#060b14] border-t border-slate-800/60">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

          <a
            href="/peliculas"
            class="group flex items-center gap-5 p-6 rounded-2xl bg-slate-900/60 border border-slate-700/50 hover:border-blue-500/40 hover:-translate-y-1 hover:shadow-xl hover:shadow-blue-900/20 transition-all duration-300"
          >
            <div class="w-14 h-14 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center flex-shrink-0 group-hover:bg-blue-600/30 transition-colors">
              <i class="fa-solid fa-film text-blue-400 text-xl" />
            </div>
            <div>
              <h3 class="font-['Bebas_Neue'] text-2xl text-white tracking-wide group-hover:text-blue-300 transition-colors">
                Explorar Películas
              </h3>
              <p class="text-slate-400 text-sm mt-0.5">
                Más de 800 títulos: estrenos, clásicos y próximos estrenos.
              </p>
            </div>
            <i class="fa-solid fa-arrow-right ml-auto text-slate-600 group-hover:text-blue-400 group-hover:translate-x-1 transition-all" />
          </a>

          <a
            href="/resenas"
            class="group flex items-center gap-5 p-6 rounded-2xl bg-slate-900/60 border border-slate-700/50 hover:border-amber-500/40 hover:-translate-y-1 hover:shadow-xl hover:shadow-amber-900/20 transition-all duration-300"
          >
            <div class="w-14 h-14 rounded-xl bg-amber-600/20 border border-amber-500/30 flex items-center justify-center flex-shrink-0 group-hover:bg-amber-600/30 transition-colors">
              <i class="fa-solid fa-star-half-stroke text-amber-400 text-xl" />
            </div>
            <div>
              <h3 class="font-['Bebas_Neue'] text-2xl text-white tracking-wide group-hover:text-amber-300 transition-colors">
                Leer Reseñas
              </h3>
              <p class="text-slate-400 text-sm mt-0.5">
                Análisis profundos de temporada, actuaciones y fotografía.
              </p>
            </div>
            <i class="fa-solid fa-arrow-right ml-auto text-slate-600 group-hover:text-amber-400 group-hover:translate-x-1 transition-all" />
          </a>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .clasico-card article:hover {
    border-color: rgba(245, 158, 11, 0.35) !important;
    box-shadow: 0 20px 60px rgba(217, 119, 6, 0.18);
  }
  .clasico-card article:hover h3 {
    color: #fbbf24 !important;
  }

  .proximo-card article:hover {
    border-color: rgba(6, 182, 212, 0.35) !important;
    box-shadow: 0 20px 60px rgba(6, 182, 212, 0.14);
  }
  .proximo-card article:hover h3 {
    color: #22d3ee !important;
  }
</style>
