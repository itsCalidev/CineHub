---
// src/components/Header.astro
const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/peliculas", label: "Películas" },
  { href: "/series", label: "Series" },
  { href: "/resenas", label: "Reseñas" },
  { href: "/noticias", label: "Noticias" },
  { href: "/galardonadas", label: "Galardonadas" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <!-- Barra superior decorativa -->
  <div class="h-[3px] bg-gradient-to-r from-blue-600 via-blue-400 to-cyan-400"></div>

  <nav
    class="flex items-center justify-between px-6 lg:px-12 py-4"
    aria-label="Navegación principal"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" aria-label="Cine-Hub Inicio">
      <div
        class="w-9 h-9 bg-blue-600 rounded flex items-center justify-center shadow-lg shadow-blue-900/50 group-hover:bg-blue-500 transition-colors"
      >
        <i class="fa-solid fa-film text-white text-sm"></i>
      </div>
      <span class="font-['Bebas_Neue'] text-2xl tracking-widest">
        <span class="text-blue-500">CINE</span><span class="text-white">-HUB</span>
      </span>
    </a>

    <!-- Desktop Nav Links -->
    <ul class="hidden lg:flex items-center gap-1" role="list">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "relative px-4 py-2 text-sm font-medium tracking-wide transition-colors duration-200 rounded",
                "hover:text-blue-400 group",
                currentPath === href
                  ? "text-blue-400"
                  : "text-slate-300",
              ]}
            >
              {label}
              <span
                class:list={[
                  "absolute bottom-0 left-1/2 -translate-x-1/2 h-[2px] bg-blue-500 transition-all duration-300 rounded-full",
                  currentPath === href
                    ? "w-4/5"
                    : "w-0 group-hover:w-4/5",
                ]}
              />
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <!-- Search -->
      <button
        aria-label="Buscar"
        class="w-9 h-9 flex items-center justify-center text-slate-400 hover:text-blue-400 transition-colors"
      >
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>

      <!-- CTA -->
      <a
        href="#contacto"
        class="hidden sm:inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold rounded transition-all duration-200 shadow-lg shadow-blue-900/40 hover:shadow-blue-700/40"
      >
        <i class="fa-solid fa-envelope text-xs"></i>
        Contacto
      </a>

      <!-- Hamburger (mobile) -->
      <button
        id="menu-toggle"
        aria-label="Abrir menú"
        aria-expanded="false"
        class="lg:hidden w-9 h-9 flex flex-col items-center justify-center gap-[5px] text-slate-300"
      >
        <span class="menu-line w-6 h-[2px] bg-current rounded transition-all duration-300"></span>
        <span class="menu-line w-4 h-[2px] bg-current rounded transition-all duration-300 self-end"></span>
        <span class="menu-line w-6 h-[2px] bg-current rounded transition-all duration-300"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-slate-800/60 bg-[#0a0f1a]/98 backdrop-blur-xl px-6 pb-6"
  >
    <ul class="mt-4 space-y-1" role="list">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "flex items-center gap-3 px-3 py-3 rounded-lg text-sm font-medium transition-colors",
                currentPath === href
                  ? "text-blue-400 bg-blue-900/20"
                  : "text-slate-300 hover:text-blue-400 hover:bg-slate-800/50",
              ]}
            >
              <span class="w-1.5 h-1.5 bg-blue-500 rounded-full opacity-70" />
              {label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href="#contacto"
      class="mt-4 flex items-center justify-center gap-2 w-full py-3 bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold rounded-lg transition-colors"
    >
      <i class="fa-solid fa-envelope text-xs"></i>
      Escríbenos
    </a>
  </div>
</header>

<script>
  // Header scroll effect
  const header = document.getElementById("main-header");
  const nav = header?.querySelector("nav");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 60) {
      header?.classList.add("bg-[#0a0f1a]/95", "backdrop-blur-xl", "shadow-lg", "shadow-black/40");
    } else {
      header?.classList.remove("bg-[#0a0f1a]/95", "backdrop-blur-xl", "shadow-lg", "shadow-black/40");
    }
  });

  // Mobile menu toggle
  const toggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const lines = toggle?.querySelectorAll(".menu-line");

  toggle?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));

    if (!isOpen && lines) {
      lines[0].classList.add("rotate-45", "translate-y-[7px]");
      lines[1].classList.add("opacity-0", "w-0");
      lines[2].classList.add("-rotate-45", "-translate-y-[7px]");
    } else if (lines) {
      lines[0].classList.remove("rotate-45", "translate-y-[7px]");
      lines[1].classList.remove("opacity-0", "w-0");
      lines[2].classList.remove("-rotate-45", "-translate-y-[7px]");
    }
  });
</script>
