---
// src/components/MovieCard.astro

export interface Props {
  title: string;
  description: string;
  image: string;
  trailer: string;
  anio?: number;
  director?: string;
  duracion?: string;
  calificacion?: number | null;
  genero?: string[];
  showCategoria?: boolean;
  categoria?: "reciente" | "clasico" | "proximo";
}

const {
  title,
  description,
  image,
  trailer,
  anio,
  director,
  duracion,
  calificacion,
  genero = [],
  showCategoria = false,
  categoria,
} = Astro.props;

const categoriaLabel: Record<string, string> = {
  reciente:  "Estreno",
  clasico:   "Clásico",
  proximo:   "Próximamente",
};

const categoriaColor: Record<string, string> = {
  reciente: "bg-blue-600/20 text-blue-400 border-blue-500/30",
  clasico:  "bg-amber-600/20 text-amber-400 border-amber-500/30",
  proximo:  "bg-cyan-600/20  text-cyan-400  border-cyan-500/30",
};

const starsFull  = calificacion ? Math.floor(calificacion / 2) : 0;
const starsEmpty = 5 - starsFull;
---

<article
  class="
    group relative flex flex-col rounded-2xl overflow-hidden
    bg-slate-900 border border-slate-700/50
    hover:border-blue-500/40
    transition-all duration-400 ease-out
    hover:-translate-y-2 hover:shadow-2xl hover:shadow-blue-900/30
    cursor-pointer
  "
>
  <div class="relative overflow-hidden aspect-[2/3] max-h-72">
    <img
      src={image}
      alt={`Póster de ${title}`}
      loading="lazy"
      decoding="async"
      class="
        w-full h-full object-cover object-center
        transition-transform duration-700 ease-out
        group-hover:scale-110
      "
    />

    <div
      class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/40 to-transparent"
    />

    {showCategoria && categoria && (
      <span
        class={`
          absolute top-3 left-3 px-3 py-1 rounded-full
          border text-xs font-semibold uppercase tracking-widest
          backdrop-blur-sm
          ${categoriaColor[categoria]}
        `}
      >
        {categoriaLabel[categoria]}
      </span>
    )}

    {calificacion !== null && calificacion !== undefined && (
      <div
        class="
          absolute top-3 right-3
          w-10 h-10 rounded-full
          bg-slate-900/80 backdrop-blur-sm
          border border-slate-600/60
          flex items-center justify-center
          text-white font-['Bebas_Neue'] text-base leading-none
        "
        title={`Calificación: ${calificacion}/10`}
      >
        {calificacion}
      </div>
    )}

    <div
      class="
        absolute inset-0 flex items-center justify-center
        bg-blue-950/60 backdrop-blur-[2px]
        opacity-0 group-hover:opacity-100
        transition-opacity duration-300
      "
    >
      <a
        href={trailer}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Ver tráiler de ${title}`}
        class="
          w-16 h-16 rounded-full
          bg-blue-600 hover:bg-blue-500
          flex items-center justify-center
          shadow-xl shadow-blue-900/60
          transition-transform duration-200 hover:scale-110
          active:scale-95
        "
        onclick="event.stopPropagation()"
      >
        <i class="fa-solid fa-play text-white text-xl ml-1"></i>
      </a>
    </div>
  </div>

  <div class="flex flex-col flex-1 p-5 gap-3">

    {genero.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {genero.slice(0, 3).map((g) => (
          <span class="px-2 py-0.5 rounded bg-slate-800 text-slate-400 text-[10px] font-medium uppercase tracking-wider border border-slate-700/60">
            {g}
          </span>
        ))}
      </div>
    )}

    <h3
      class="
        font-['Bebas_Neue'] text-2xl leading-tight tracking-wide
        text-white group-hover:text-blue-300
        transition-colors duration-300
        line-clamp-2
      "
    >
      {title}
    </h3>

    <div class="flex items-center flex-wrap gap-x-3 gap-y-1 text-xs text-slate-500">
      {anio && (
        <span class="flex items-center gap-1">
          <i class="fa-solid fa-calendar-days text-blue-500/70 text-[10px]" />
          {anio}
        </span>
      )}
      {director && (
        <>
          <span class="w-[1px] h-3 bg-slate-700" />
          <span class="flex items-center gap-1">
            <i class="fa-solid fa-clapperboard text-blue-500/70 text-[10px]" />
            {director}
          </span>
        </>
      )}
      {duracion && duracion !== "TBD" && (
        <>
          <span class="w-[1px] h-3 bg-slate-700" />
          <span class="flex items-center gap-1">
            <i class="fa-regular fa-clock text-blue-500/70 text-[10px]" />
            {duracion}
          </span>
        </>
      )}
    </div>

    {calificacion !== null && calificacion !== undefined && (
      <div
        class="flex items-center gap-1"
        aria-label={`Calificación: ${calificacion} de 10`}
      >
        {Array.from({ length: starsFull }, (_, i) => (
          <i class="fa-solid fa-star text-yellow-400 text-xs" />
        ))}
        {Array.from({ length: starsEmpty }, (_, i) => (
          <i class="fa-regular fa-star text-slate-600 text-xs" />
        ))}
        <span class="ml-1 text-slate-500 text-[11px]">({calificacion}/10)</span>
      </div>
    )}

    <p class="text-slate-400 text-sm leading-relaxed line-clamp-3 flex-1">
      {description}
    </p>

    <a
      href={trailer}
      target="_blank"
      rel="noopener noreferrer"
      class="
        mt-auto flex items-center justify-center gap-2
        py-2.5 px-4 rounded-xl
        bg-blue-600/10 hover:bg-blue-600
        border border-blue-500/30 hover:border-blue-500
        text-blue-400 hover:text-white
        text-sm font-semibold
        transition-all duration-250
        group/btn
      "
    >
      <i
        class="
          fa-solid fa-circle-play text-base
          transition-transform duration-200
          group-hover/btn:scale-110
        "
      />
      Ver Tráiler
      <i
        class="
          fa-solid fa-arrow-up-right-from-square text-[10px]
          opacity-50 group-hover/btn:opacity-100
          transition-opacity
        "
      />
    </a>
  </div>
</article>
