---
// src/components/Footer.astro
const year = new Date().getFullYear();

const footerLinks = {
  explorar: [
    { href: "/peliculas", label: "Películas" },
    { href: "/series", label: "Series" },
    { href: "/resenas", label: "Reseñas" },
    { href: "/noticias", label: "Noticias" },
    { href: "/galardonadas", label: "Galardonadas" },
  ],
  soporte: [
    { href: "#", label: "Acerca de nosotros" },
    { href: "#contacto", label: "Contacto" },
  ],
};
---

<footer class="bg-[#060b14] border-t border-slate-800/60">
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-flex items-center gap-2 mb-5">
          <div class="w-9 h-9 bg-blue-600 rounded flex items-center justify-center">
            <i class="fa-solid fa-film text-white text-sm"></i>
          </div>
          <span class="font-['Bebas_Neue'] text-2xl tracking-widest">
            <span class="text-blue-500">CINE</span><span class="text-white">-HUB</span>
          </span>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed max-w-sm mb-6">
          Tu portal de confianza para reseñas, noticias y recomendaciones de cine.
          Apasionados y unidos por el séptimo arte desde 2023.
        </p>
        <!-- Social Icons -->
        <div class="flex items-center gap-3">
          {[
            { icon: "fa-brands fa-twitter", href: "#", label: "Twitter" },
            { icon: "fa-brands fa-instagram", href: "#", label: "Instagram" },
            { icon: "fa-brands fa-youtube", href: "#", label: "YouTube" },
            { icon: "fa-brands fa-letterboxd", href: "#", label: "Letterboxd" },
          ].map(({ icon, href, label }) => (
            <a
              href={href}
              aria-label={label}
              class="w-9 h-9 rounded-lg bg-slate-800 hover:bg-blue-600 flex items-center justify-center text-slate-400 hover:text-white transition-all duration-200"
            >
              <i class={`${icon} text-sm`}></i>
            </a>
          ))}
        </div>
      </div>

      <!-- Explorar links -->
      <div>
        <h4 class="text-white font-['Barlow_Condensed'] font-semibold uppercase tracking-widest text-xs mb-5 text-blue-400">
          Explorar
        </h4>
        <ul class="space-y-3">
          {footerLinks.explorar.map(({ href, label }) => (
            <li>
              <a href={href} class="text-slate-400 hover:text-blue-400 text-sm transition-colors flex items-center gap-2 group">
                <span class="w-0 h-[1px] bg-blue-500 group-hover:w-3 transition-all duration-300 rounded" />
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Soporte links -->
      <div>
        <h4 class="text-white font-['Barlow_Condensed'] font-semibold uppercase tracking-widest text-xs mb-5 text-blue-400">
          Compañía
        </h4>
        <ul class="space-y-3">
          {footerLinks.soporte.map(({ href, label }) => (
            <li>
              <a href={href} class="text-slate-400 hover:text-blue-400 text-sm transition-colors flex items-center gap-2 group">
                <span class="w-0 h-[1px] bg-blue-500 group-hover:w-3 transition-all duration-300 rounded" />
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Center Bottom bar -->
  <div class="border-t border-slate-800/60 py-5 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-3">
      <p class="text-slate-500 text-sm">
        © {year} <span class="text-blue-500">Cine-Hub</span>. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
